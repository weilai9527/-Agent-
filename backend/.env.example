# Server
PORT=3001
APP_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173
COOKIE_SECURE=false

# Password reset is deferred by default. Enable it only after an email service is available.
PASSWORD_RESET_ENABLED=false
PASSWORD_RESET_URL_BASE=http://127.0.0.1:5173/
PASSWORD_RESET_SMTP_HOST=
PASSWORD_RESET_SMTP_PORT=587
PASSWORD_RESET_SMTP_USERNAME=
PASSWORD_RESET_SMTP_PASSWORD=
PASSWORD_RESET_EMAIL_FROM=
PASSWORD_RESET_SMTP_USE_TLS=true
PASSWORD_RESET_SMTP_USE_SSL=false
PASSWORD_RESET_SMTP_TIMEOUT=10
PASSWORD_RESET_RATE_WINDOW=900
PASSWORD_RESET_RATE_EMAIL_MAX=3
PASSWORD_RESET_RATE_IP_MAX=10

# Database
DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=multi_agent_interview
MYSQL_CHARSET=utf8mb4

# Follow-up and resume-analysis provider order.
# Empty keys and placeholder keys are ignored. Dedicated text API keys are
# recommended; voice-key fallback is kept only for backward compatibility.
FOLLOWUP_PROVIDER_ORDER=qwen,openai,kimi,deepseek,custom
PROVIDER_HTTP_RETRIES=2
RESUME_ANALYSIS_PROVIDER_ORDER=qwen,openai,kimi,deepseek,custom
RESUME_ANALYSIS_MAX_TOKENS=1400
RESUME_ANALYSIS_TIMEOUT=45

# Custom OpenAI-compatible text provider
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT=20
AI_TEMPERATURE=0.55
AI_MAX_TOKENS=160

# OpenAI text provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FOLLOWUP_MODEL=gpt-4o-mini
OPENAI_FOLLOWUP_TIMEOUT=20
OPENAI_FOLLOWUP_TEMPERATURE=0.55
OPENAI_FOLLOWUP_MAX_TOKENS=160

# Kimi text provider
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_TIMEOUT=20
KIMI_TEMPERATURE=0.55
KIMI_MAX_TOKENS=160

# DeepSeek text provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=20
DEEPSEEK_TEMPERATURE=0.55
DEEPSEEK_MAX_TOKENS=160

# Qwen text provider. Optional when DASHSCOPE_API_KEY is set.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT=20
QWEN_TRUST_ENV=true
QWEN_TEMPERATURE=0.55
QWEN_MAX_TOKENS=160

# AI evaluation and report generation. Provider names reuse the text-provider settings above.
EVALUATION_PROVIDER_ORDER=qwen,openai,kimi,deepseek,custom
REPORT_PROVIDER_ORDER=qwen,openai,kimi,deepseek,custom
AI_EVALUATION_MAX_TOKENS=1200
AI_EVALUATION_TIMEOUT=30
AI_EVALUATION_HTTP_RETRIES=1
AI_EVALUATION_PROVIDER_ATTEMPTS=2
AI_REPORT_MAX_TOKENS=2600
AI_REPORT_TIMEOUT=60
AI_REPORT_HTTP_RETRIES=1
AI_REPORT_PROVIDER_ATTEMPTS=2
AI_PROVIDER_HEALTH_TIMEOUT=20

# OpenAI Realtime voice. Falls back to OPENAI_API_KEY if this is empty.
OPENAI_REALTIME_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper

# DashScope shared key for Qwen text fallback, CosyVoice TTS, and Qwen-Omni fallback.
DASHSCOPE_API_KEY=
DASHSCOPE_TTS_MODEL=cosyvoice-v3-flash
DASHSCOPE_TTS_VOICE=longanyang
DASHSCOPE_TTS_REGION=beijing
DASHSCOPE_WORKSPACE_ID=
SSL_CERT_FILE=
WEBSOCKET_CLIENT_CA_BUNDLE=

# DashScope realtime TTS
DASHSCOPE_REALTIME_TTS_MODEL=cosyvoice-v3-flash
DASHSCOPE_REALTIME_TTS_VOICE=longanyang
DASHSCOPE_REALTIME_TTS_FORMAT=mp3
DASHSCOPE_REALTIME_TTS_SAMPLE_RATE=22050
DASHSCOPE_REALTIME_TTS_VOLUME=50
DASHSCOPE_REALTIME_TTS_RATE=1.0
DASHSCOPE_REALTIME_TTS_PITCH=1.0
DASHSCOPE_REALTIME_TTS_LANGUAGE_HINT=zh
DASHSCOPE_REALTIME_TTS_INSTRUCTION=
DASHSCOPE_REALTIME_TTS_CHUNK_SIZE=240
DASHSCOPE_REALTIME_TTS_TIMEOUT=15

# Qwen-Omni Realtime. Uses QWEN_OMNI_REALTIME_API_KEY, then QWEN_OMNI_API_KEY,
# then DASHSCOPE_API_KEY.
QWEN_OMNI_REALTIME_API_KEY=
QWEN_OMNI_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_OMNI_REALTIME_VOICE=Tina
# Optional when DASHSCOPE_WORKSPACE_ID is already configured.
QWEN_OMNI_REALTIME_WORKSPACE_ID=
# Both URL fields are optional when a Workspace ID and supported region are configured.
QWEN_OMNI_REALTIME_WEBRTC_URL=
QWEN_OMNI_REALTIME_WEBRTC_ENDPOINT=
QWEN_OMNI_REALTIME_WEBRTC_TIMEOUT=30
QWEN_OMNI_REALTIME_REGION=beijing
QWEN_OMNI_REALTIME_TRANSCRIPTION_MODEL=qwen3-asr-flash-realtime
QWEN_OMNI_REALTIME_TURN_DETECTION=semantic_vad
QWEN_OMNI_REALTIME_VAD_THRESHOLD=0.5
QWEN_OMNI_REALTIME_PREFIX_PADDING_MS=500
QWEN_OMNI_REALTIME_SILENCE_DURATION_MS=800
QWEN_OMNI_REALTIME_SMOOTH_OUTPUT=false
QWEN_OMNI_REALTIME_ENABLE_SEARCH=false
QWEN_OMNI_REALTIME_SEARCH_SOURCE=true

# Optional self-hosted Qwen-Omni websocket gateway.
QWEN_OMNI_REALTIME_WS_URL=
QWEN_OMNI_REALTIME_MAX_MESSAGE_SIZE=16777216

# Qwen-Omni non-realtime HTTP fallback.
QWEN_OMNI_API_KEY=
QWEN_OMNI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_OMNI_MODEL=qwen3.5-omni-plus
QWEN_OMNI_VOICE=Tina
QWEN_OMNI_INPUT_AUDIO_FORMAT=webm
QWEN_OMNI_OUTPUT_AUDIO_FORMAT=wav
QWEN_OMNI_TIMEOUT=120

# Optional: required only for OCR on scanned/image-only resumes. If Tesseract is
# already available on PATH, leave this empty.
TESSERACT_CMD=
