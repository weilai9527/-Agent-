DB_ENGINE=sqlite
SQLITE_PATH=../backend/data/dev.sqlite

# MySQL 部署时再切换：
# DB_ENGINE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=multi_agent_interview
MYSQL_CHARSET=utf8mb4

ADMIN_FRONTEND_ORIGIN=http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Independent administrator authentication.
# Configure these values before the first startup. The bootstrap account is
# created only when the email does not already exist.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=系统管理员
ADMIN_BOOTSTRAP_ROLE=super_admin
ADMIN_SESSION_MAX_AGE=28800
ADMIN_COOKIE_SECURE=false
