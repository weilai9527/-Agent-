OPENAI_FOLLOWUP_MODEL=gpt-4o-mini
OPENAI_FOLLOWUP_TIMEOUT=20
OPENAI_FOLLOWUP_TEMPERATURE=0.55
OPENAI_FOLLOWUP_MAX_TOKENS=160
FOLLOWUP_PROVIDER_ORDER=kimi,deepseek,qwen,openai,custom
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_TIMEOUT=20
KIMI_TEMPERATURE=0.55
KIMI_MAX_TOKENS=160
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=20
DEEPSEEK_TEMPERATURE=0.55
DEEPSEEK_MAX_TOKENS=160
QWEN_API_KEY=your-dashscope-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT=20
QWEN_TEMPERATURE=0.55
QWEN_MAX_TOKENS=160
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
DASHSCOPE_API_KEY=your-dashscope-api-key
