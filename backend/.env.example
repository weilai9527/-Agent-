PORT=3001
APP_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=multi_agent_interview
MYSQL_CHARSET=utf8mb4
COOKIE_SECURE=false
AI_API_KEY=your-api-key-here
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT=20
AI_TEMPERATURE=0.55
AI_MAX_TOKENS=160
OPENAI_API_KEY=your-api-key-here
